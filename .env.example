# 24시간 무중단 클라우드 배포용 환경변수 템플릿
# 로컬 개발 및 클라우드(Render 등) 배포 시 아래 값을 채워 환경변수로 설정하세요.

PORT=3000

# 1. 이메일 직접 전송용 Gmail 설정 (구글 앱 비밀번호 발급 필요)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-digit-app-password

# 2. 이미지 영구 클라우드 보관용 Cloudinary 설정
# Cloudinary 대시보드에서 'API Environment variable' 값을 복사해서 입력하세요.
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
